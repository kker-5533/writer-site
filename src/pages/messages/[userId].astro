---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import PlatformNav from '../../components/PlatformNav.astro';
import Footer from '../../components/Footer.astro';
import fs from 'node:fs';
import path from 'node:path';

const { userId } = Astro.params;

function getUser(id: string) {
  try {
    const users = JSON.parse(fs.readFileSync(path.join(process.cwd(), 'src/data/users.json'), 'utf-8'));
    return users.find((u: any) => u.id === id);
  } catch { return null; }
}
const partner = getUser(userId);
if (!partner) return Astro.redirect('/messages');
---

<Layout>
  <PlatformNav />
  <div class="chat-page">
    <div class="container">
      <a href="/messages" class="chat-back">&larr; 收件箱</a>
      <h1>{partner.nickname}</h1>
      <div class="chat-box" id="chatBox"><p class="inbox-empty">暂无消息</p></div>
      <form class="chat-form" id="chatForm">
        <textarea id="chatInput" placeholder="输入消息..." rows="2" maxlength="2000"></textarea>
        <button type="submit">发送</button>
      </form>
    </div>
  </div>
  <Footer author="文学社" tagline="发现好文字，遇见好作者" />
</Layout>

<script define:vars={{ partnerId: userId, partnerName: partner.nickname, partnerRole: partner.role }}>
  var userStr = sessionStorage.getItem('linshen_user');
  var auth = sessionStorage.getItem('linshen_auth');
  if (auth !== 'true' || !userStr) { window.location.href = '/login'; }
  var me = JSON.parse(userStr);

  var chatBox = document.getElementById('chatBox');
  var chatForm = document.getElementById('chatForm');
  var chatInput = document.getElementById('chatInput');

  function fmtTime(t) {
    if (!t) return '';
    var d = new Date(t);
    var now = new Date();
    var diff = now.getTime() - d.getTime();
    var absolute = d.toISOString().slice(0, 10) + ' ' + d.toTimeString().slice(0, 5);
    if (diff < 3600000) return absolute + '（' + Math.floor(diff / 60000) + ' 分钟前）';
    return absolute;
  }

  function getSender(id) {
    if (id === me.id) return { name: '我', role: me.role };
    return { name: partnerName, role: partnerRole };
  }

  async function loadMessages() {
    try {
      var res = await fetch('/api/private-messages?userId=' + me.id + '&with=' + partnerId);
      var msgs = await res.json();
      if (!msgs.length) { chatBox.innerHTML = '<p class="inbox-empty">暂无消息，发送第一条吧</p>'; return; }

      chatBox.innerHTML = msgs.map(function(m) {
        var s = getSender(m.from);
        var roleLabel = s.role === 'admin' ? '管理员' : '作者';
        var isRead = m.read ? '已读' : '未读';
        return '<div class="chat-card">' +
          '<div class="chat-card-head"><strong>' + esc(s.name) + '</strong><em class="' + (s.role === 'admin' ? 'badge-admin' : '') + '">' + roleLabel + '</em><span class="chat-card-time">' + fmtTime(m.time) + '</span><span class="chat-card-status ' + (m.read ? 'read' : '') + '">' + isRead + '</span></div>' +
          '<p class="chat-card-body">' + esc(m.body) + '</p>' +
        '</div>';
      }).join('');
      chatBox.scrollTop = chatBox.scrollHeight;
    } catch(e) {}
  }

  chatForm.addEventListener('submit', async function(e) {
    e.preventDefault();
    var body = chatInput.value.trim();
    if (!body) return;
    var btn = chatForm.querySelector('button');
    btn.disabled = true;
    try {
      await fetch('/api/private-messages', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ from: me.id, to: partnerId, body: body }) });
      chatInput.value = '';
      loadMessages();
    } catch(e) {}
    btn.disabled = false;
    chatInput.focus();
  });

  function esc(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  loadMessages();
  setInterval(loadMessages, 30000);
</script>

<style>
  .page { padding: 100px 0 60px; min-height: 70vh; display: flex; flex-direction: column; }
  .container { flex: 1; display: flex; flex-direction: column; max-width: 680px; }
  .page h1 { font-family: var(--font-heading); font-size: 22px; color: var(--navy); margin-bottom: 20px; text-align: center; }
  .back { font-size: 13px; color: var(--text-light); text-decoration: none; display: block; margin-bottom: 8px; }
  .back:hover { color: var(--teal); }
  .empty { color: var(--text-light); padding: 60px 0; text-align: center; font-size: 15px; }
  .chat-box { flex: 1; max-height: 55vh; overflow-y: auto; padding: 8px 4px; display: flex; flex-direction: column; gap: 8px; }
  .cm-card {
    padding: 14px 18px; border: 1px solid var(--border); border-radius: 10px;
    background: #fff; display: flex; flex-direction: column; gap: 6px;
  }
  .cm-head { display: flex; align-items: center; gap: 8px; }
  .cm-head strong { font-size: 14px; color: var(--navy); }
  .cm-head em { font-style: normal; font-size: 11px; padding: 1px 6px; border-radius: 3px; background: var(--teal); color: #fff; }
  .cm-time { font-size: 12px; color: var(--text-light); margin-left: auto; }
  .cm-status { font-size: 11px; color: var(--text-light); }
  .cm-status.read { color: #4a8a4a; }
  .cm-body { font-size: 15px; color: var(--text-dark); line-height: 1.8; margin: 0; }
  .chat-form {
    display: flex; gap: 10px; margin-top: 20px; padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  .chat-form textarea {
    flex: 1; padding: 12px 14px; font-family: var(--font-body); font-size: 14px;
    border: 1px solid var(--border); border-radius: 12px; background: var(--cream);
    color: var(--text-dark); outline: none; resize: none;
  }
  .chat-form textarea:focus { border-color: var(--teal); background: #fff; }
  .chat-form button {
    padding: 12px 28px; font-family: var(--font-body); font-size: 14px; font-weight: 600;
    letter-spacing: 1px; background: var(--navy); color: #fff;
    border: none; border-radius: 12px; cursor: pointer; white-space: nowrap;
    align-self: flex-end;
  }
  .chat-form button:hover { background: #243548; }
  .chat-form button:disabled { opacity: 0.6; }
  @media (max-width: 640px) { .page { padding: 80px 0 40px; } }
</style>
