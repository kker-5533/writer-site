---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import PlatformNav from '../../components/PlatformNav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout>
  <PlatformNav />
  <div class="inbox-page">
    <div class="container">
      <h1>我的来信</h1>
      <div id="inboxList"><p class="inbox-empty">加载中...</p></div>
    </div>
  </div>
  <Footer author="文学社" tagline="发现好文字，遇见好作者" />
</Layout>

<script>
  var userStr = sessionStorage.getItem('linshen_user');
  var auth = sessionStorage.getItem('linshen_auth');
  if (auth !== 'true' || !userStr) { window.location.href = '/login'; }
  var me = JSON.parse(userStr);

  async function loadInbox() {
    var list = document.getElementById('inboxList');
    try {
      var res = await fetch('/api/private-messages?userId=' + me.id);
      var data = await res.json();
      var convs = data.conversations || [];
      var unread = data.unread || 0;

      var h1 = document.querySelector('h1');
      if (h1) h1.textContent = '我的来信' + (unread > 0 ? '（' + unread + ' 条未读）' : '');

      if (!convs.length) { list.innerHTML = '<p class="inbox-empty">暂无来信</p>'; return; }

      // 获取用户列表以确定角色
      var usersRes = await fetch('/api/auth', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ action: 'list', adminId: me.id }) });
      var users = [];
      if (usersRes.ok) users = await usersRes.json();
      var userMap = {};
      users.forEach(function(u) { userMap[u.id] = u; });

      list.innerHTML = convs.map(function(c) {
        var isUnread = !c.read && c.from !== me.id;
        var partner = userMap[c.partner] || {};
        var name = partner.nickname || c.partnerName || '未知';
        var roleLabel = partner.role === 'admin' ? '管理员' : '作者';
        return '<a href="/messages/' + c.partner + '" class="inbox-card' + (isUnread ? ' unread' : '') + '">' +
          '<span class="inbox-dot"></span>' +
          '<span class="inbox-body">' +
            '<span class="inbox-line1"><strong>' + esc(name) + '</strong><em>' + roleLabel + '</em><span class="inbox-time">' + fmtTime(c.time) + ' 来信</span></span>' +
            '<span class="inbox-line2">' + esc(c.lastMsg || '').slice(0, 80) + '</span>' +
          '</span>' +
        '</a>';
      }).join('');
    } catch(e) { list.innerHTML = '<p class="inbox-empty">加载失败</p>'; }
  }

  function fmtTime(t) {
    if (!t) return '';
    var d = new Date(t);
    var now = new Date();
    var diff = now.getTime() - d.getTime();
    if (diff < 60000) return '刚刚';
    if (diff < 3600000) return Math.floor(diff / 60000) + ' 分钟前';
    if (diff >= 3600000) return d.toISOString().slice(0, 10) + ' ' + d.toTimeString().slice(0, 5);
    return '';
  }

  function esc(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  loadInbox();
</script>

<style>
  @media (max-width: 640px) { .inbox-page { padding: 80px 0 40px; } .inbox-card { padding: 14px 16px; } }
</style>
