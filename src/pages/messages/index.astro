---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import PlatformNav from '../../components/PlatformNav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout>
  <PlatformNav />
  <div class="page">
    <div class="container">
      <h1>我的来信</h1>
      <div id="inboxList"><p class="empty">加载中...</p></div>
    </div>
  </div>
  <Footer author="文学社" tagline="发现好文字，遇见好作者" />
</Layout>

<script>
  var userStr = sessionStorage.getItem('linshen_user');
  var auth = sessionStorage.getItem('linshen_auth');
  if (auth !== 'true' || !userStr) { window.location.href = '/login'; }
  var me = JSON.parse(userStr);

  async function loadInbox() {
    var list = document.getElementById('inboxList');
    try {
      var res = await fetch('/api/private-messages?userId=' + me.id);
      var data = await res.json();
      var convs = data.conversations || [];
      var unread = data.unread || 0;

      var h1 = document.querySelector('h1');
      if (h1) h1.textContent = '我的来信' + (unread > 0 ? '（' + unread + ' 条未读）' : '');

      if (!convs.length) { list.innerHTML = '<p class="empty">暂无来信<br><span class="hint">在作者主页下方可发送私信</span></p>'; return; }

      list.innerHTML = convs.map(function(c) {
        var isUnread = !c.read && c.from !== me.id;
        var name = c.partnerName || '未知用户';
        var initials = (name || '?')[0];
        var hue = (name.charCodeAt(0) || 0) * 137 % 360;
        return '<a href="/messages/' + c.partner + '" class="msg-card' + (isUnread ? ' unread' : '') + '">' +
          '<span class="card-avatar" style="background:hsl(' + hue + ',45%,55%)">' + initials + '</span>' +
          '<span class="card-body">' +
            '<span class="card-top"><strong>' + esc(name) + '</strong>' +
            (isUnread ? '<em class="card-badge">未读</em>' : '') +
            '</span>' +
            '<span class="card-time">' + fmtTime(c.time) + ' 来信</span>' +
            '<span class="card-text">' + esc(c.lastMsg || '').slice(0, 60) + '</span>' +
          '</span>' +
        '</a>';
      }).join('');
    } catch(e) { list.innerHTML = '<p class="empty">加载失败</p>'; }
  }

  function fmtTime(t) {
    if (!t) return '';
    var d = new Date(t);
    var now = new Date();
    var diff = now.getTime() - d.getTime();
    if (diff < 60000) return '刚刚';
    if (diff < 3600000) return Math.floor(diff / 60000) + ' 分钟前';
    if (diff < 86400000) return Math.floor(diff / 3600000) + ' 小时前';
    if (diff < 604800000) return Math.floor(diff / 86400000) + ' 天前';
    return d.toISOString().slice(0, 10);
  }

  function esc(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  loadInbox();
</script>

<style>
  .page { padding: 100px 0 60px; min-height: 70vh; }
  .page h1 { font-family: var(--font-heading); font-size: 26px; color: var(--navy); margin-bottom: 28px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
  .empty { color: var(--text-light); padding: 60px 0; text-align: center; font-size: 15px; }
  .hint { font-size: 13px; color: var(--text-light); display: block; margin-top: 6px; }
  .msg-card {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 16px 20px; margin-bottom: 8px;
    border: 1px solid var(--border); border-radius: 10px;
    background: #fff; text-decoration: none; transition: all 0.15s;
  }
  .msg-card:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.05); border-color: var(--teal-light); }
  .msg-card.unread { background: #fafefe; border-left: 3px solid var(--teal); }
  .card-avatar {
    width: 42px; height: 42px; border-radius: 50%; color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 17px; font-weight: 700; flex-shrink: 0;
  }
  .card-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
  .card-top { display: flex; align-items: center; gap: 8px; }
  .card-top strong { font-size: 15px; color: var(--navy); }
  .card-badge { font-style: normal; font-size: 11px; padding: 1px 7px; border-radius: 8px; background: var(--teal); color: #fff; font-weight: 600; }
  .card-time { font-size: 12px; color: var(--text-light); }
  .card-text { font-size: 13.5px; color: var(--text-mid); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  @media (max-width: 640px) { .page { padding: 80px 0 40px; } .msg-card { padding: 14px 16px; } }
</style>
