---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import InteractionBar from '../../components/InteractionBar.astro';
import fs from 'node:fs';
import path from 'node:path';

const { slug } = Astro.params;
const filePath = path.join(process.cwd(), 'src/content/blog', `${slug}.json`);

let post;
try {
  post = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
} catch {
  return Astro.redirect('/');
}

const bodyHtml = (post.body || '').replace(/\n/g, '<br>');
---

<Layout>
  <Nav />
  <div class="reading-progress" id="progress"></div>
  <article class="reader">
    <header class="reader-header">
      <a href="/#blog" class="back-link">&larr; 随笔</a>
      <h1>{post.title}</h1>
      <p class="date">{post.date}</p>
    </header>

    <div class="reader-body" set:html={bodyHtml} />
    <InteractionBar slug={`blog/${slug}`} />
  </article>
  <Footer author="林深" tagline="由内而外地安静生长" />
</Layout>

<script>
  window.addEventListener('scroll', () => {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
    const bar = document.getElementById('progress');
    if (bar) bar.style.width = progress + '%';
  });
</script>

<style>
  .reading-progress {
    position: fixed; top: 42px; left: 0; z-index: 19;
    height: 3px; background: linear-gradient(90deg, var(--teal), var(--gold));
    width: 0%; transition: width 0.1s linear;
  }
  .reader {
    max-width: 680px; margin: 0 auto; padding: 80px 28px 60px;
  }
  .reader-header {
    text-align: center; margin-bottom: 56px; padding-top: 20px;
  }
  .back-link {
    display: inline-block; margin-bottom: 32px;
    font-family: var(--font-body); font-size: 13px;
    color: var(--text-light); text-decoration: none;
    letter-spacing: 1px; transition: color 0.2s;
  }
  .back-link:hover { color: var(--teal); }
  .reader-header h1 {
    font-family: var(--font-heading);
    font-size: 36px; font-weight: 900;
    color: var(--navy); letter-spacing: 2px;
    margin-bottom: 12px; line-height: 1.3;
  }
  .date {
    font-family: var(--font-body); font-size: 14px;
    color: var(--teal); letter-spacing: 0.5px;
  }
  .reader-body {
    font-family: var(--font-heading);
    font-size: 17px; line-height: 2.2; color: var(--text-dark);
    letter-spacing: 0.3px;
  }
  .reader-body :global(h2) {
    font-family: var(--font-heading);
    font-size: 24px; font-weight: 700; color: var(--navy);
    margin: 48px 0 20px;
  }
  .reader-body :global(p) {
    margin-bottom: 22px;
  }

  @media (max-width: 640px) {
    .reader { padding: 60px 20px 40px; }
    .reader-header h1 { font-size: 28px; }
    .reader-body { font-size: 16px; line-height: 2; }
    .reading-progress { top: 35px; }
  }
</style>
