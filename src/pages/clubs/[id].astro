---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import PlatformNav from '../../components/PlatformNav.astro';
import Footer from '../../components/Footer.astro';
import fs from 'node:fs';
import path from 'node:path';

const { id } = Astro.params;

function getClub(cid: string) { try { const clubs = JSON.parse(fs.readFileSync(path.join(process.cwd(), 'src/data/clubs.json'), 'utf-8')); return clubs.find((c: any) => c.id === cid); } catch { return null; } }
function loadWorks() { const dir = path.join(process.cwd(), 'src/content/works'); try { return fs.readdirSync(dir).filter((f: string) => f.endsWith('.json')).map((f: string) => ({ id: f.replace('.json',''), ...JSON.parse(fs.readFileSync(path.join(dir, f), 'utf-8')) })); } catch { return []; } }
function getEvents() { try { return JSON.parse(fs.readFileSync(path.join(process.cwd(), 'src/data/events.json'), 'utf-8')); } catch { return []; } }
function getUsers() { try { return JSON.parse(fs.readFileSync(path.join(process.cwd(), 'src/data/users.json'), 'utf-8')); } catch { return []; } }

const club = getClub(id);
if (!club) return Astro.redirect('/clubs');

const works: any[] = loadWorks();
const approved = works.filter((w: any) => !w.reviewStatus || w.reviewStatus === 'approved');
const events = getEvents();
const users = getUsers();
const authors = users.filter((u: any) => u.recommended && u.status === 'active');
---

<Layout>
  <PlatformNav />
  <div class="page">
    <div class="container">
      <a href="/clubs" class="back">&larr; 所有社团</a>

      <header class="club-hero">
        <div class="club-ava-lg">{club.name[0]}</div>
        <h1>{club.name}</h1>
        <p class="club-desc">{club.intro}</p>
        <span class="club-founder">发起人：{club.createdBy}</span>
      </header>

      <section class="sec">
        <div class="sec-head"><h2>近期活动</h2><span class="sec-line"></span><a href="/events">全部 →</a></div>
        <div class="ev-row">
          {events.slice(0,3).map((e: any) => (
            <a href={`/events/${e.id}`} class="ev-card">
              <span class="ev-tag">活动</span>
              <h4>{e.title}</h4>
              <p class="ev-date">截止 {e.deadline}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="sec">
        <div class="sec-head"><h2>推荐作品</h2><span class="sec-line"></span><a href="/recommended-works">全部 →</a></div>
        <div class="wk-grid">
          {approved.slice(0,4).map((w: any) => (
            <a href={`/works/${w.id}`} class="wk-card">
              <span class="wk-tag">{w.type}</span>
              <h3>{w.title}</h3>
              <p class="wk-meta">{w.authorName || '佚名'} · {w.year}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="sec">
        <div class="sec-head"><h2>推荐作者</h2><span class="sec-line"></span><a href="/recommended-authors">全部 →</a></div>
        <div class="au-grid">
          {authors.slice(0,4).map((u: any) => (
            <a href={`/author/${u.id}`} class="au-card">
              <div class="au-ava">{u.nickname[0]}</div>
              <div class="au-name">{u.nickname}</div>
            </a>
          ))}
        </div>
      </section>

      <section class="sec">
        <div class="sec-head"><h2>联系方式</h2><span class="sec-line"></span></div>
        <div class="contact-box"><p>📧 {club.contact || '暂无'}</p></div>
      </section>

      <section class="submit-box">
        <h2>投稿通道</h2>
        <p>欢迎向本社团投稿。注册成为作者后，在个人后台发布作品即可。</p>
        <a href="/register" class="btn">注 册 作 者</a>
      </section>

    </div>
  </div>
  <Footer author="文学社" tagline="由内而外地安静生长" />
</Layout>

<style>
  .page { padding: 100px 0 60px; background: var(--bg); min-height: 70vh; }
  .container { max-width: 780px; margin: 0 auto; padding: 0 32px; }
  .back { font-size: 13px; color: var(--text-light); text-decoration: none; display: block; margin-bottom: 32px; }
  .back:hover { color: var(--accent); }

  .club-hero { text-align: center; padding: 20px 0 48px; }
  .club-ava-lg { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(145deg, var(--navy), var(--teal)); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 30px; font-weight: 700; margin: 0 auto 16px; }
  .club-hero h1 { font-size: 30px; font-weight: 800; color: var(--navy); margin-bottom: 10px; }
  .club-desc { font-size: 15px; color: var(--text-mid); max-width: 480px; margin: 0 auto 12px; line-height: 1.8; }
  .club-founder { font-size: 13px; color: var(--text-light); }

  .sec { margin-bottom: 48px; }
  .sec-head { display: flex; align-items: baseline; gap: 12px; margin-bottom: 22px; }
  .sec-head h2 { font-size: 18px; font-weight: 800; letter-spacing: 2px; color: var(--navy); white-space: nowrap; }
  .sec-line { flex: 1; height: 1px; background: var(--border); }
  .sec-head a { font-size: 12px; font-weight: 600; color: var(--text-light); text-decoration: none; }
  .sec-head a:hover { color: var(--accent); }

  .ev-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; }
  .ev-card { background: var(--white); border: 1px solid var(--border); box-shadow: var(--shadow-sm); padding: 20px; text-decoration: none; color: inherit; transition: all .3s; display: block; }
  .ev-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-hover); }
  .ev-tag { font-size: 10px; font-weight: 700; letter-spacing: 2px; color: var(--accent); display: block; margin-bottom: 8px; }
  .ev-card h4 { font-size: 16px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
  .ev-date { font-size: 12px; color: var(--text-light); }

  .wk-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .wk-card { background: var(--white); border: 1px solid var(--border); box-shadow: var(--shadow-sm); padding: 22px; text-decoration: none; color: inherit; transition: all .3s; display: block; }
  .wk-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-hover); }
  .wk-tag { font-size: 10px; font-weight: 700; letter-spacing: 2px; color: var(--accent); display: block; margin-bottom: 8px; }
  .wk-card h3 { font-size: 19px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
  .wk-meta { font-size: 12px; color: var(--text-light); font-weight: 500; }

  .au-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; }
  .au-card { text-align: center; background: var(--white); border: 1px solid var(--border); box-shadow: var(--shadow-sm); padding: 24px 12px; text-decoration: none; color: inherit; transition: all .3s; display: block; }
  .au-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-hover); }
  .au-ava { width: 52px; height: 52px; border-radius: 50%; background: var(--navy); color: #fff; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px; font-size: 18px; font-weight: 700; }
  .au-name { font-size: 14px; font-weight: 700; color: var(--navy); }

  .contact-box { background: var(--white); border: 1px solid var(--border); box-shadow: var(--shadow-sm); padding: 20px; }
  .contact-box p { font-size: 14px; color: var(--text-mid); }

  .submit-box { text-align: center; padding: 36px; background: var(--white); border: 1px solid var(--border); box-shadow: var(--shadow-sm); }
  .submit-box h2 { font-size: 20px; font-weight: 800; color: var(--navy); margin-bottom: 8px; }
  .submit-box p { font-size: 14px; color: var(--text-mid); margin-bottom: 18px; }
  .btn { display: inline-block; padding: 12px 32px; background: var(--navy); color: #fff; text-decoration: none; font-size: 14px; font-weight: 700; letter-spacing: 3px; box-shadow: 0 6px 0 rgba(0,0,0,.1); transition: all .2s; }
  .btn:hover { transform: translateY(2px); box-shadow: 0 3px 0 rgba(0,0,0,.1); }

  @media (max-width: 640px) { .ev-row,.wk-grid { grid-template-columns: 1fr; } .au-grid { grid-template-columns: repeat(2,1fr); } }
</style>
