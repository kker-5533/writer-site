---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import PlatformNav from '../components/PlatformNav.astro';
import Footer from '../components/Footer.astro';
import fs from 'node:fs';
import path from 'node:path';

function readJSON(fp: string) {
  try { return JSON.parse(fs.readFileSync(path.join(process.cwd(), fp), 'utf-8')); } catch { return null; }
}
function loadWorks() {
  const dir = path.join(process.cwd(), 'src/content/works');
  try { const files = fs.readdirSync(dir).filter((f: string) => f.endsWith('.json')); return files.map((f: string) => ({ id: f.replace('.json', ''), ...JSON.parse(fs.readFileSync(path.join(dir, f), 'utf-8')) })); } catch { return []; }
}
function loadBlog() {
  const dir = path.join(process.cwd(), 'src/content/blog');
  try { const files = fs.readdirSync(dir).filter((f: string) => f.endsWith('.json')); return files.map((f: string) => ({ id: f.replace('.json', ''), ...JSON.parse(fs.readFileSync(path.join(dir, f), 'utf-8')) })); } catch { return []; }
}

const allWorks: any[] = loadWorks();
const approvedWorks = allWorks.filter((w: any) => !w.reviewStatus || w.reviewStatus === 'approved');
const featuredWorks = approvedWorks.filter((w: any) => w.recommended);

const allPosts: any[] = loadBlog();
const publishedPosts = allPosts.filter((p: any) => !p.draft).sort((a: any, b: any) => b.date.localeCompare(a.date));

const siteData = readJSON('src/data/site.json') || {};
const users = readJSON('src/data/users.json') || [];
const recommendedAuthors = users.filter((u: any) => u.recommended && u.status === 'active');
---

<Layout>
  <PlatformNav />

  <header class="hero">
    <div class="hero-text">
      <span class="overline">LITERARY SOCIETY</span>
      <h1>{siteData.author || '文学社'}<br>{siteData.subtitle || '发现好文字，遇见好作者'}</h1>
      <p class="hero-desc">{siteData.intro || '文学社是一个开放的文字栖息地。每一篇作品都是一次相遇，每一个作者都值得被阅读。'}</p>
      <a href="/recommended-works" class="cta-btn">开 始 阅 读</a>
    </div>
    <div class="hero-grid">
      {approvedWorks.slice(0,4).map((w: any, i: number) => (
        <a href={`/works/${w.id}`} class={`hg-cell hg-${i+1}`}>
          <span class="hg-num">0{i+1}</span>
          <span class="hg-tag">{['本期力荐','编辑精选','新作速递','读者推荐'][i]}</span>
          <h3>{w.title}</h3>
          <p class="hg-author">{w.authorName || '佚名'} · {w.type}</p>
          <span class="hg-arrow">→</span>
        </a>
      ))}
    </div>
  </header>

  <section class="sec">
    <div class="sec-inner">
      <div class="sec-head"><h2>推荐作品</h2><span class="sec-line"></span><a href="/recommended-works">全部 →</a></div>
      <div class="card-grid2" id="worksGrid">
        {approvedWorks.slice(0,8).map((w: any) => (
          <a href={`/works/${w.id}`} class="c-card">
            <span class="c-tag">{w.type}</span>
            <h3>{w.title}</h3>
            <p class="c-meta">{w.authorName || '佚名'} · {w.year}{w.wordCount ? ' · '+w.wordCount : ''}</p>
            <p class="c-desc">{(w.summary || '').slice(0,80)}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="sec-inner">
      <div class="sec-head"><h2>推荐作者</h2><span class="sec-line"></span><a href="/recommended-authors">全部 →</a></div>
      <div class="author-grid" id="authorsGrid">
        {recommendedAuthors.concat(users.filter((u: any) => u.role === 'author' && u.status === 'active' && !u.recommended)).slice(0,6).map((u: any, i: number) => (
          <a href={`/author/${u.id}`} class="a-card">
            <div class={`a-ava a-ava-${(i%4)+1}`}>{u.nickname[0]}</div>
            <div class="a-name">{u.nickname}</div>
            <div class="a-role">{u.role === 'admin' ? '创办人' : '作者'}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="sec-inner">
      <div class="sec-head"><h2>最新随笔</h2><span class="sec-line"></span></div>
      <div class="card-grid2" id="blogGrid">
        {publishedPosts.slice(0,6).map((p: any) => (
          <a href={`/blog/${p.id}`} class="c-card">
            <span class="c-date">{p.date}</span>
            <h3>{p.title}</h3>
            <p class="c-meta">{p.authorName || '佚名'}</p>
            <p class="c-desc">{(p.excerpt || '').slice(0,80)}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer author={siteData.author || '文学社'} tagline="由内而外地安静生长" />
</Layout>

<script>
(function(){
  function makeCarousel(gridId, n) {
    var grid = document.getElementById(gridId);
    if (!grid || grid.children.length <= n) return;
    var items = grid.children, total = items.length, batches = Math.ceil(total/n), cur = 0;
    var btn = document.createElement('div');
    btn.className = 'cycle-btn';
    btn.textContent = '换 一 批';
    btn.addEventListener('click', function(){
      cur = (cur + 1) % batches;
      for (var i = 0; i < total; i++) { items[i].style.display = (i >= cur*n && i < cur*n+n) ? '' : 'none'; }
      btn.textContent = '换 一 批（' + (cur+1) + '/' + batches + '）';
    });
    grid.parentNode.insertBefore(btn, grid.nextSibling);
    for (var i = 0; i < total; i++) { if (i >= n) items[i].style.display = 'none'; }
  }
  makeCarousel('worksGrid', 4);
  makeCarousel('authorsGrid', 4);
  makeCarousel('blogGrid', 4);
})();
</script>

<style>
  /* ===== Hero ===== */
  .hero {
    display: grid; grid-template-columns: 1fr 1fr; gap: 56px;
    max-width: 1100px; margin: 0 auto; padding: 80px 48px 60px;
    align-items: center; min-height: 70vh;
  }
  .hero-text .overline { font-size: 10px; font-weight: 700; letter-spacing: 5px; color: var(--accent); margin-bottom: 24px; display: block; }
  .hero-text h1 { font-size: 50px; font-weight: 800; letter-spacing: -1px; line-height: 1.12; color: var(--navy); margin-bottom: 18px; }
  .hero-text .hero-desc { font-size: 16px; line-height: 1.8; color: var(--text-mid); margin-bottom: 36px; max-width: 440px; }
  .cta-btn {
    display: inline-block; padding: 15px 38px; background: var(--navy); color: #fff;
    text-decoration: none; font-size: 14px; font-weight: 700; letter-spacing: 3px;
    box-shadow: 0 8px 0 rgba(0,0,0,.1); transition: all .2s;
  }
  .cta-btn:hover { transform: translateY(2px); box-shadow: 0 4px 0 rgba(0,0,0,.1); }

  .hero-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    width: 320px; height: 320px; gap: 1px;
    background: var(--border);
  }
  .hg-cell {
    background: rgba(255,255,255,.9); backdrop-filter: blur(8px);
    padding: 24px 20px; display: flex; flex-direction: column;
    justify-content: center; text-decoration: none; color: inherit;
    transition: all .4s cubic-bezier(.22,.61,.36,1);
    position: relative; overflow: hidden;
  }
  .hg-cell:hover { background: #fff; transform: scale(1.03); z-index: 2; box-shadow: 0 8px 32px rgba(0,0,0,.12); }
  .hg-num { font-size: 40px; font-weight: 900; color: rgba(0,0,0,.04); position: absolute; top: 8px; right: 14px; font-family: "Songti SC",serif; }
  .hg-tag { font-size: 9px; font-weight: 700; letter-spacing: 3px; color: var(--accent); margin-bottom: 8px; display: block; }
  .hg-cell h3 { font-size: 16px; font-weight: 700; color: var(--navy); margin-bottom: 4px; line-height: 1.3; }
  .hg-author { font-size: 11px; color: var(--text-light); }
  .hg-arrow { position: absolute; bottom: 14px; right: 16px; font-size: 14px; color: var(--border); transition: all .3s; }
  .hg-cell:hover .hg-arrow { color: var(--accent); right: 12px; }

  /* ===== 通用区域 ===== */
  .sec { padding: 40px 48px; }
  .sec-inner { max-width: 1100px; margin: 0 auto; }
  .sec-head { display: flex; align-items: baseline; gap: 12px; margin-bottom: 36px; }
  .sec-head h2 { font-size: 21px; font-weight: 800; letter-spacing: 3px; color: var(--navy); white-space: nowrap; }
  .sec-line { flex: 1; height: 1px; background: var(--border); }
  .sec-head a { font-size: 12px; font-weight: 600; color: var(--text-light); text-decoration: none; white-space: nowrap; }
  .sec-head a:hover { color: var(--navy); }

  /* ===== 内容卡片 ===== */
  .card-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .c-card {
    background: var(--white); padding: 36px; border: 1px solid var(--border);
    box-shadow: var(--shadow-md); transition: all .35s; position: relative;
    text-decoration: none; color: inherit; display: block;
  }
  .c-card::after { content: ''; position: absolute; bottom: 0; left: 6px; right: 6px; height: 10px; background: rgba(0,0,0,.03); filter: blur(6px); z-index: -1; transition: all .35s; }
  .c-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-hover); }
  .c-card:hover::after { bottom: -6px; height: 14px; opacity: .6; }
  .c-tag, .c-date { font-size: 10px; font-weight: 700; letter-spacing: 3px; color: var(--accent); margin-bottom: 12px; display: block; }
  .c-card h3 { font-size: 22px; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
  .c-meta { font-size: 14px; color: var(--text-muted); font-weight: 600; margin-bottom: 12px; }
  .c-desc { font-size: 14px; line-height: 1.7; color: var(--text-mid); }

  /* ===== 作者卡片 ===== */
  .author-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 18px; }
  .a-card {
    text-align: center; background: var(--white); padding: 36px 16px; border: 1px solid var(--border);
    box-shadow: var(--shadow-sm); transition: all .35s; text-decoration: none; color: inherit; display: block;
  }
  .a-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-hover); }
  .a-ava {
    width: 62px; height: 62px; border-radius: 50%; margin: 0 auto 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; font-weight: 700; color: #fff;
    box-shadow: inset 0 2px 4px rgba(255,255,255,.2), 0 4px 8px rgba(0,0,0,.1);
  }
  .a-ava-1 { background: linear-gradient(145deg,#3d3858,#5a5280); }
  .a-ava-2 { background: linear-gradient(145deg,#5a6b5a,#7a907a); }
  .a-ava-3 { background: linear-gradient(145deg,#8a6b4a,#b08a5e); }
  .a-ava-4 { background: linear-gradient(145deg,#5a6b6a,#7a9090); }
  .a-name { font-size: 15px; font-weight: 700; color: var(--navy); }
  .a-role { font-size: 12px; color: var(--text-light); margin-top: 4px; }

  /* ===== 轮播按钮 ===== */
  .cycle-btn {
    display: block; text-align: center; margin-top: 24px; padding: 14px 0;
    font-size: 14px; font-weight: 700; color: var(--accent); cursor: pointer;
    letter-spacing: 4px; border: 1px solid var(--border); background: var(--white);
    transition: all .25s; user-select: none;
  }
  .cycle-btn:hover { background: var(--navy); color: #fff; border-color: var(--navy); }

  /* ===== 空状态 ===== */
  .empty { color: var(--text-light); padding: 40px 0; text-align: center; font-size: 15px; }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; padding: 40px 24px; min-height: auto; gap: 32px; }
    .hero-grid { width: 280px; height: 280px; }
    .hero-text h1 { font-size: 34px; }
    .card-grid2 { grid-template-columns: 1fr; }
    .author-grid { grid-template-columns: repeat(2,1fr); }
    .sec { padding: 32px 24px; }
  }
</style>
