---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="login-wrapper">
    <div class="login-card">
      <h1>林 深</h1>
      <p class="sub">内容管理系统</p>

      <form id="loginForm" class="login-form">
        <div class="field">
          <label for="nickname">昵称</label>
          <input type="text" id="nickname" name="nickname" placeholder="请输入昵称" autocomplete="off" />
        </div>
        <div class="field">
          <label for="password">密码</label>
          <input type="password" id="password" name="password" placeholder="请输入密码" />
        </div>
        <p id="error" class="error" style="display:none">昵称或密码错误</p>
        <button type="submit">登 录</button>
      </form>

      <a href="/" class="back">&larr; 返回首页</a>
    </div>
  </div>
</Layout>

<script>
  const VALID_NICKNAME = '0000';
  const VALID_PASSWORD = '0000';

  const form = document.getElementById('loginForm');
  const errorEl = document.getElementById('error');

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const nickname = document.getElementById('nickname').value.trim();
    const password = document.getElementById('password').value;

    if (nickname === VALID_NICKNAME && password === VALID_PASSWORD) {
      sessionStorage.setItem('linshen_auth', 'true');
      window.location.href = '/admin/';
    } else {
      errorEl.style.display = 'block';
    }
  });
</script>

<style>
  .login-wrapper {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    background: var(--cream);
    padding: 40px 24px;
  }
  .login-card {
    background: var(--white);
    border-radius: 12px;
    padding: 56px 48px 40px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 2px 24px rgba(0,0,0,0.06);
    text-align: center;
  }
  .login-card h1 {
    font-family: var(--font-heading);
    font-size: 28px; font-weight: 700;
    color: var(--navy);
    letter-spacing: 6px;
    margin-bottom: 6px;
  }
  .login-card .sub {
    font-size: 12.5px; color: var(--text-light);
    letter-spacing: 2px;
    margin-bottom: 40px;
  }
  .login-form { display: flex; flex-direction: column; gap: 20px; }
  .field { text-align: left; }
  .field label {
    display: block;
    font-family: var(--font-body);
    font-size: 12px; font-weight: 600;
    color: var(--text-mid);
    letter-spacing: 1px;
    margin-bottom: 6px;
  }
  .field input {
    width: 100%; padding: 12px 14px;
    font-family: var(--font-body);
    font-size: 15px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--cream);
    color: var(--text-dark);
    outline: none;
    transition: border-color 0.2s;
  }
  .field input:focus {
    border-color: var(--teal);
    background: var(--white);
  }
  .error {
    font-size: 13px; color: #c44;
    text-align: center;
  }
  .login-form button {
    padding: 13px;
    font-family: var(--font-body);
    font-size: 14px; font-weight: 600;
    letter-spacing: 4px;
    background: var(--navy);
    color: #fff;
    border: none; border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 4px;
  }
  .login-form button:hover { background: #243548; }
  .back {
    display: inline-block; margin-top: 28px;
    font-size: 13px; color: var(--text-light);
    text-decoration: none;
    transition: color 0.2s;
  }
  .back:hover { color: var(--teal); }
</style>
