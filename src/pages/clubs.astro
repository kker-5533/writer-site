---
import Layout from '../layouts/Layout.astro';
import PlatformNav from '../components/PlatformNav.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <PlatformNav />
  <div class="page">
    <div class="container">
      <h1>文学社团</h1>
      <div class="placeholder">
        <p>敬请期待</p>
        <span>诗歌社、小说工坊、散文沙龙……即将上线</span>
      </div>
    </div>
  </div>
  <Footer author="文学社" tagline="发现好文字，遇见好作者" />
</Layout>

<style>
  .page { padding: 100px 0 60px; min-height: 60vh; }
  .page h1 { font-family: var(--font-heading); font-size: 28px; color: var(--navy); margin-bottom: 36px; }
  .placeholder { text-align: center; padding: 80px 0; }
  .placeholder p { font-family: var(--font-heading); font-size: 20px; color: var(--text-mid); margin-bottom: 8px; }
  .placeholder span { font-size: 14px; color: var(--text-light); }
</style>
