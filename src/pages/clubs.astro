---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import PlatformNav from '../components/PlatformNav.astro';
import Footer from '../components/Footer.astro';
import fs from 'node:fs';
import path from 'node:path';

function getClubs() { try { return JSON.parse(fs.readFileSync(path.join(process.cwd(), 'src/data/clubs.json'), 'utf-8')); } catch { return []; } }
const clubs = getClubs();
---

<Layout>
  <PlatformNav />
  <div class="page">
    <div class="container">
      <h1>文学社团</h1>
      <p class="subtitle">加入感兴趣的社团，找到同好</p>
      <div class="grid">
        {clubs.map((c: any) => (
          <a href={`/clubs/${c.id}`} class="club-card">
            <div class="club-ava">{c.name[0]}</div>
            <h3>{c.name}</h3>
            <p class="club-intro">{c.intro}</p>
            <span class="club-founder">发起人：{c.createdBy}</span>
            <span class="club-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </div>
  <Footer author="文学社" tagline="由内而外地安静生长" />
</Layout>

<style>
  .page { padding: 100px 0 60px; min-height: 70vh; background: var(--bg); }
  .container { max-width: 860px; margin: 0 auto; padding: 0 32px; }
  .page h1 { font-size: 28px; font-weight: 800; color: var(--navy); letter-spacing: 2px; margin-bottom: 8px; }
  .subtitle { font-size: 14px; color: var(--text-muted); margin-bottom: 36px; }
  .grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; }
  .club-card {
    background: var(--white); border: 1px solid var(--border);
    box-shadow: var(--shadow-sm); padding: 32px 28px;
    text-decoration: none; color: inherit; transition: all .35s;
    position: relative; display: block;
  }
  .club-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); }
  .club-ava {
    width: 64px; height: 64px; border-radius: 50%;
    background: linear-gradient(145deg, var(--navy), var(--teal));
    color: #fff; display: flex; align-items: center; justify-content: center;
    font-size: 24px; font-weight: 700; margin-bottom: 16px;
  }
  .club-card h3 { font-size: 22px; font-weight: 800; color: var(--navy); margin-bottom: 10px; }
  .club-intro { font-size: 14px; color: var(--text-mid); line-height: 1.7; margin-bottom: 14px; }
  .club-founder { font-size: 12px; color: var(--text-light); font-weight: 500; }
  .club-arrow { position: absolute; bottom: 24px; right: 28px; font-size: 20px; color: rgba(0,0,0,.08); transition: all .3s; }
  .club-card:hover .club-arrow { color: var(--accent); right: 24px; }
  @media (max-width: 640px) { .grid { grid-template-columns: 1fr; } }
</style>
