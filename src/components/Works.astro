---
import type { CollectionEntry } from 'astro:content';

interface Props {
  works: CollectionEntry<'works'>[];
}

const { works } = Astro.props;
const sorted = works.sort((a, b) => b.data.year - a.data.year);
---

<section id="works">
  <div class="container">
    <p class="section-tag">Works</p>
    <h2 class="section-title">作品</h2>

    {sorted.map((w, i) => (
      <div class="work-item">
        <span class="num">{String(i + 1).padStart(2, '0')}</span>
        <div class="info">
          <span class="title">{w.data.title}</span>
          <span class="meta">
            {w.data.type} · {w.data.year} 年{w.data.wordCount && ` · 约 ${w.data.wordCount} 字`}{w.data.published && w.data.publisher && ` · ${w.data.publisher}`}
          </span>
          <p class="desc">{w.data.summary}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .work-item {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 16px 0;
    padding: 32px 0;
    border-bottom: 1px solid var(--border-light);
    align-items: start;
  }
  .work-item:last-child { border-bottom: none; padding-bottom: 0; }
  .work-item .num {
    font-family: var(--font-heading);
    font-size: 15px; font-weight: 600;
    color: var(--teal-light);
    padding-top: 2px;
  }
  .work-item .info { display: flex; flex-direction: column; gap: 6px; }
  .work-item .title {
    font-family: var(--font-heading);
    font-size: 21px; font-weight: 700;
    color: var(--navy);
    letter-spacing: 1px;
  }
  .work-item .meta {
    font-family: var(--font-body);
    font-size: 12.5px; font-weight: 500;
    color: var(--teal);
    letter-spacing: 0.8px;
  }
  .work-item .desc {
    font-size: 14.5px; color: var(--text-mid); line-height: 1.95;
    margin-top: 6px;
  }
  @media (max-width: 640px) {
    .work-item { grid-template-columns: 36px 1fr; }
  }
</style>
