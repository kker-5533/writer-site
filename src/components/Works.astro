---
interface Props {
  works: any[];
  interactions: Record<string, { likes: number; urges: number }>;
}

const { works, interactions } = Astro.props;
// 兼容两种数据格式: Astro collection entries 或纯 JSON 对象
const normalized = works.map((w: any) => w.title ? w : { id: w.id, ...w.data });
const sorted = normalized.filter((w: any) => w.body).sort((a: any, b: any) => b.year - a.year);
---

<section id="works">
  <div class="container">
    <p class="section-tag">Works</p>
    <h2 class="section-title">作品</h2>

    {sorted.map((w, i) => {
      const counts = interactions[`works/${w.id}`] || { likes: 0, urges: 0 };
      return (
      <div class="work-item">
        <span class="num">{String(i + 1).padStart(2, '0')}</span>
        <div class="info">
          <a href={`/works/${w.id}`} class="title">{w.title}</a>
          <span class="meta">
            {w.type} · {w.year} 年{w.wordCount && ` · 约 ${w.wordCount} 字`}{w.published && w.publisher && ` · ${w.publisher}`}
          </span>
          <p class="desc">{w.summary}</p>
          <span class="counts-mini">
            <span class="mini-like">♥ {counts.likes}</span>
            <span class="mini-urge">⚡ {counts.urges}</span>
          </span>
        </div>
      </div>
    )})}
  </div>
</section>

<style>
  .work-item {
    display: grid; grid-template-columns: 48px 1fr; gap: 16px 0;
    padding: 28px 32px; margin-bottom: 12px;
    background: var(--white); border: 1px solid var(--border);
    box-shadow: var(--shadow-sm); align-items: start;
    transition: all .35s;
  }
  .work-item:hover { transform: translateY(-2px); box-shadow: var(--shadow-hover); }
  .work-item:last-child { margin-bottom: 0; }
  .work-item .num { font-size: 14px; font-weight: 700; color: var(--accent); padding-top: 2px; }
  .work-item .info { display: flex; flex-direction: column; gap: 6px; }
  .work-item .title { font-family: var(--font-heading); font-size: 20px; font-weight: 700; color: var(--navy); letter-spacing: 1px; text-decoration: none; transition: color 0.25s; }
  .work-item .title:hover { color: var(--accent); }
  .work-item .meta { font-size: 12px; font-weight: 500; color: var(--text-light); letter-spacing: 0.5px; }
  .work-item .desc { font-size: 14px; color: var(--text-mid); line-height: 1.8; margin-top: 4px; }
  .counts-mini { display: flex; gap: 14px; margin-top: 8px; font-size: 12px; font-weight: 600; }
  .mini-like { color: var(--accent); }
  .mini-urge { color: #c44; }
  @media (max-width: 640px) { .work-item { grid-template-columns: 36px 1fr; padding: 20px 18px; } }
</style>
