---
interface Props {
  works: any[];
  interactions: Record<string, { likes: number; urges: number }>;
}

const { works, interactions } = Astro.props;
// 兼容两种数据格式: Astro collection entries 或纯 JSON 对象
const normalized = works.map((w: any) => w.title ? w : { id: w.id, ...w.data });
const sorted = normalized.filter((w: any) => w.body).sort((a: any, b: any) => b.year - a.year);
---

<section id="works">
  <div class="container">
    <p class="section-tag">Works</p>
    <h2 class="section-title">作品</h2>

    {sorted.map((w, i) => {
      const counts = interactions[`works/${w.id}`] || { likes: 0, urges: 0 };
      return (
      <div class="work-item">
        <span class="num">{String(i + 1).padStart(2, '0')}</span>
        <div class="info">
          <a href={`/works/${w.id}`} class="title">{w.title}</a>
          <span class="meta">
            {w.type} · {w.year} 年{w.wordCount && ` · 约 ${w.wordCount} 字`}{w.published && w.publisher && ` · ${w.publisher}`}
          </span>
          <p class="desc">{w.summary}</p>
          <span class="counts-mini">
            <span class="mini-like">♥ {counts.likes}</span>
            <span class="mini-urge">⚡ {counts.urges}</span>
          </span>
        </div>
      </div>
    )})}
  </div>
</section>

<style>
  .work-item {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 16px 0;
    padding: 32px 0;
    border-bottom: 1px solid var(--border-light);
    align-items: start;
  }
  .work-item:last-child { border-bottom: none; padding-bottom: 0; }
  .work-item .num {
    font-family: var(--font-heading);
    font-size: 15px; font-weight: 600;
    color: var(--teal-light);
    padding-top: 2px;
  }
  .work-item .info { display: flex; flex-direction: column; gap: 6px; }
  .work-item .title {
    font-family: var(--font-heading);
    font-size: 21px; font-weight: 700;
    color: var(--navy);
    letter-spacing: 1px;
    text-decoration: none;
    transition: color 0.25s;
  }
  .work-item .title:hover { color: var(--gold); }
  .work-item .meta {
    font-family: var(--font-body);
    font-size: 12.5px; font-weight: 500;
    color: var(--teal);
    letter-spacing: 0.8px;
  }
  .work-item .desc {
    font-size: 14.5px; color: var(--text-mid); line-height: 1.95;
    margin-top: 6px;
  }
  .counts-mini {
    display: flex; gap: 14px; margin-top: 8px;
    font-family: var(--font-body); font-size: 12px; font-weight: 500;
  }
  .mini-like { color: var(--teal); }
  .mini-urge { color: var(--coral); }
  @media (max-width: 640px) {
    .work-item { grid-template-columns: 36px 1fr; }
  }
</style>
