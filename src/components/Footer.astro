---
interface Props {
  author: string;
  tagline: string;
}

const { author, tagline } = Astro.props;
const year = new Date().getFullYear();
---

<footer>
  <span>&copy; {year} {author}</span>
  <span class="divider">&middot;</span>
  <span>{tagline}</span>
</footer>

<style>
  footer {
    text-align: center; padding: 60px 28px 44px;
    font-family: var(--font-body);
    font-size: 12.5px; font-weight: 400;
    color: rgba(255,255,255,0.45);
    background: var(--navy);
    letter-spacing: 1px;
  }
  footer .divider { margin: 0 12px; color: rgba(255,255,255,0.18); }
</style>
