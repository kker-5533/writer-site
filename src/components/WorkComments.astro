---
const { slug } = Astro.props;
const safeId = slug.replace(/[^a-zA-Z0-9一-鿿]/g, '-');
---

<section class="work-comments" id={`wcm-${safeId}`}>
  <h3>作品留言</h3>

  <div class="wc-list" id={`wcList-${safeId}`}>
    <p class="wc-empty">暂无留言</p>
  </div>

  <form class="wc-form" id={`wcForm-${safeId}`}>
    <div class="wc-row">
      <input type="text" id={`wcAuthor-${safeId}`} placeholder="你的昵称" maxlength="20" required />
      <button type="submit">提交留言</button>
    </div>
    <textarea id={`wcBody-${safeId}`} placeholder="对这篇作品说些什么..." rows="3" maxlength="1000" required></textarea>
    <p class="wc-msg" id={`wcMsg-${safeId}`}></p>
  </form>
</section>

<script define:vars={{ slug, safeId }}>
  (function() {
    const list = document.getElementById('wcList-' + safeId);
    const form = document.getElementById('wcForm-' + safeId);
    const authorEl = document.getElementById('wcAuthor-' + safeId);
    const bodyEl = document.getElementById('wcBody-' + safeId);
    const msgEl = document.getElementById('wcMsg-' + safeId);
    if (!list || !form) return;

    async function load() {
      try {
        const res = await fetch('/api/work-messages?slug=' + encodeURIComponent(slug));
        const msgs = await res.json();
        if (!msgs.length) { list.innerHTML = '<p class="wc-empty">暂无留言，来做第一个留言的读者吧。</p>'; return; }
        list.innerHTML = msgs.map(m =>
          `<div class="wc-item"><div class="wc-head"><span class="wc-author">${esc(m.author)}</span><span class="wc-time">${m.time}</span></div><p class="wc-body">${esc(m.body)}</p></div>`
        ).join('');
      } catch {}
    }

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const author = authorEl.value.trim();
      const msgBody = bodyEl.value.trim();
      if (!author || !msgBody) { showMsg('请填写昵称和留言内容', 'error'); return; }
      const btn = form.querySelector('button');
      btn.disabled = true; btn.textContent = '提交中...';
      try {
        const res = await fetch('/api/work-messages', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ slug, author, body: msgBody }) });
        const data = await res.json();
        if (data.ok) { bodyEl.value = ''; showMsg('留言成功！', 'ok'); load(); }
        else showMsg(data.error || '提交失败', 'error');
      } catch { showMsg('网络错误', 'error'); }
      btn.disabled = false; btn.textContent = '提交留言';
    });

    function showMsg(text, type) {
      if (msgEl) { msgEl.textContent = text; msgEl.className = 'wc-msg wc-' + type; setTimeout(function() { msgEl.textContent = ''; }, 3000); }
    }
    function esc(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    load();
  })();
</script>

<style>
  .work-comments {
    margin-top: 48px; padding-top: 36px;
    border-top: 1px solid var(--border);
  }
  .work-comments h3 {
    font-family: var(--font-heading);
    font-size: 19px; font-weight: 700;
    color: var(--navy); margin-bottom: 24px;
  }
  .wc-empty { color: var(--text-light); padding: 12px 0; font-size: 14px; }
  .wc-item {
    padding: 20px 0; border-bottom: 1px solid var(--border-light);
  }
  .wc-item:first-of-type { padding-top: 0; }
  .wc-head { display: flex; align-items: baseline; gap: 10px; margin-bottom: 6px; }
  .wc-author { font-size: 14px; font-weight: 600; color: var(--navy); }
  .wc-time { font-size: 11.5px; color: var(--text-light); }
  .wc-body { font-size: 14.5px; color: var(--text-mid); line-height: 1.9; }
  .wc-form { margin-top: 28px; display: flex; flex-direction: column; gap: 10px; }
  .wc-row { display: flex; gap: 10px; }
  .wc-row input {
    flex: 1; padding: 10px 12px;
    font-family: var(--font-body); font-size: 14px;
    border: 1px solid var(--border); border-radius: 6px;
    background: var(--cream); color: var(--text-dark); outline: none;
  }
  .wc-row input:focus { border-color: var(--teal); background: #fff; }
  .wc-row button {
    padding: 10px 20px; white-space: nowrap;
    font-family: var(--font-body); font-size: 13px; font-weight: 600;
    letter-spacing: 1px;
    background: var(--navy); color: #fff;
    border: none; border-radius: 6px; cursor: pointer;
  }
  .wc-row button:hover { background: #243548; }
  .wc-form textarea {
    padding: 10px 12px; resize: vertical;
    font-family: var(--font-body); font-size: 14px;
    border: 1px solid var(--border); border-radius: 6px;
    background: var(--cream); color: var(--text-dark); outline: none;
  }
  .wc-form textarea:focus { border-color: var(--teal); background: #fff; }
  .wc-msg { font-size: 13px; }
  .wc-ok { color: #4a8a4a; }
  .wc-error { color: #c44; }
  @media (max-width: 640px) {
    .wc-row { flex-direction: column; }
  }
</style>
