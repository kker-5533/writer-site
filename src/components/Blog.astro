---
interface Props {
  posts: any[];
  interactions: Record<string, { likes: number; urges: number }>;
}

const { posts, interactions } = Astro.props;
const normalized = posts.map((p: any) => p.title ? p : { id: p.id, ...p.data });
const published = normalized.filter((p: any) => !p.draft && p.body).sort((a: any, b: any) => (b.date || '').localeCompare(a.date || ''));
---

<section id="blog" class="alt">
  <div class="container">
    <p class="section-tag">Blog</p>
    <h2 class="section-title">随笔</h2>

    {published.map(p => {
      const counts = interactions[`blog/${p.id}`] || { likes: 0, urges: 0 };
      return (
      <div class="post-item">
        <span class="date">{p.date.replace(/-/g, '.')}</span>
        <div class="content">
          <a href={`/blog/${p.id}`} class="title">{p.title}</a>
          <p class="excerpt">{p.excerpt}</p>
          <span class="counts-mini">
            <span class="mini-like">♥ {counts.likes}</span>
            <span class="mini-urge">⚡ {counts.urges}</span>
          </span>
        </div>
      </div>
    )})}
  </div>
</section>

<style>
  .post-item {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 16px 24px;
    padding: 28px 0;
    border-bottom: 1px solid var(--border-light);
    align-items: baseline;
  }
  .post-item:last-child { border-bottom: none; padding-bottom: 0; }
  .post-item .date {
    font-family: var(--font-body);
    font-size: 12.5px; font-weight: 500;
    color: var(--teal);
    letter-spacing: 0.5px;
    padding-top: 3px;
    white-space: nowrap;
  }
  .post-item .content { display: flex; flex-direction: column; gap: 5px; }
  .post-item .title {
    font-family: var(--font-heading);
    font-size: 18.5px; font-weight: 700;
    color: var(--navy);
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: color 0.25s;
  }
  .post-item .title:hover { color: var(--gold); }
  .post-item .excerpt {
    font-size: 14.5px; color: var(--text-mid); line-height: 1.95;
  }
  .counts-mini {
    display: flex; gap: 14px; margin-top: 6px;
    font-family: var(--font-body); font-size: 12px; font-weight: 500;
  }
  .mini-like { color: var(--teal); }
  .mini-urge { color: var(--coral); }
  @media (max-width: 640px) {
    .post-item { grid-template-columns: 1fr; gap: 2px 0; }
    .post-item .date { padding-top: 0; }
  }
</style>
