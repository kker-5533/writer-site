---
interface Props {
  posts: any[];
  interactions: Record<string, { likes: number; urges: number }>;
}

const { posts, interactions } = Astro.props;
const normalized = posts.map((p: any) => p.title ? p : { id: p.id, ...p.data });
const published = normalized.filter((p: any) => !p.draft && p.body).sort((a: any, b: any) => (b.date || '').localeCompare(a.date || ''));
---

<section id="blog" class="alt">
  <div class="container">
    <p class="section-tag">Blog</p>
    <h2 class="section-title">随笔</h2>

    {published.map(p => {
      const counts = interactions[`blog/${p.id}`] || { likes: 0, urges: 0 };
      return (
      <div class="post-item">
        <span class="date">{p.date.replace(/-/g, '.')}</span>
        <div class="content">
          <a href={`/blog/${p.id}`} class="title">{p.title}</a>
          <p class="excerpt">{p.excerpt}</p>
          <span class="counts-mini">
            <span class="mini-like">♥ {counts.likes}</span>
            <span class="mini-urge">⚡ {counts.urges}</span>
          </span>
        </div>
      </div>
    )})}
  </div>
</section>

<style>
  .post-item {
    display: grid; grid-template-columns: 90px 1fr; gap: 12px 20px;
    padding: 24px 28px; margin-bottom: 10px;
    background: var(--white); border: 1px solid var(--border);
    box-shadow: var(--shadow-sm); align-items: baseline;
    transition: all .35s;
  }
  .post-item:hover { transform: translateY(-2px); box-shadow: var(--shadow-hover); }
  .post-item:last-child { margin-bottom: 0; }
  .post-item .date { font-size: 12px; font-weight: 600; color: var(--accent); letter-spacing: 1px; padding-top: 3px; white-space: nowrap; }
  .post-item .content { display: flex; flex-direction: column; gap: 4px; }
  .post-item .title { font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--navy); letter-spacing: .5px; text-decoration: none; transition: color .25s; }
  .post-item .title:hover { color: var(--accent); }
  .post-item .excerpt { font-size: 14px; color: var(--text-mid); line-height: 1.8; }
  .counts-mini { display: flex; gap: 14px; margin-top: 4px; font-size: 12px; font-weight: 600; }
  .mini-like { color: var(--accent); }
  .mini-urge { color: #c44; }
  @media (max-width: 640px) { .post-item { grid-template-columns: 1fr; gap: 2px 0; } .post-item .date { padding-top: 0; } }
</style>
