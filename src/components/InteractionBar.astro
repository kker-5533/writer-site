---
const { slug } = Astro.props;
const safeId = slug.replace(/[^a-zA-Z0-9一-鿿]/g, '-');
---

<div class="interaction-bar" id={`ibar-${safeId}`}>
  <button class="int-btn like-btn" id={`likeBtn-${safeId}`}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    <span id={`likeCount-${safeId}`}>0</span>
    <span class="btn-label">点赞</span>
  </button>
  <button class="int-btn urge-btn" id={`urgeBtn-${safeId}`}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
    <span id={`urgeCount-${safeId}`}>0</span>
    <span class="btn-label">催更</span>
  </button>
  <span class="int-msg" id={`intMsg-${safeId}`}></span>
</div>

<script define:vars={{ slug, safeId }}>
  (function() {
    const STORAGE_KEY = 'linshen_interacted_' + slug;

    const likeBtn = document.getElementById('likeBtn-' + safeId);
    const urgeBtn = document.getElementById('urgeBtn-' + safeId);
    const likeCount = document.getElementById('likeCount-' + safeId);
    const urgeCount = document.getElementById('urgeCount-' + safeId);
    const msgEl = document.getElementById('intMsg-' + safeId);

    if (!likeBtn || !urgeBtn) return;

    async function loadCounts() {
      try {
        const res = await fetch('/api/interactions');
        const data = await res.json();
        const counts = data[slug] || { likes: 0, urges: 0 };
        if (likeCount) likeCount.textContent = String(counts.likes);
        if (urgeCount) urgeCount.textContent = String(counts.urges);
      } catch(e) {}
    }

    function hasInteracted(action) {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]').includes(action); }
      catch { return false; }
    }

    function markInteracted(action) {
      try {
        const list = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        if (!list.includes(action)) list.push(action);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
      } catch {}
    }

    function showMsg(text) {
      if (msgEl) { msgEl.textContent = text; setTimeout(function() { msgEl.textContent = ''; }, 2000); }
    }

    likeBtn.addEventListener('click', async function() {
      if (hasInteracted('like')) { showMsg('你已经点过赞了'); return; }
      likeBtn.classList.add('active');
      markInteracted('like');
      try {
        const res = await fetch('/api/interactions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ slug: slug, action: 'like' }) });
        const data = await res.json();
        if (data.ok && likeCount) { likeCount.textContent = String(data.counts.likes); showMsg('感谢点赞！'); }
      } catch(e) {}
    });

    urgeBtn.addEventListener('click', async function() {
      if (hasInteracted('urge')) { showMsg('你已经催过了，作者在努力写呢'); return; }
      urgeBtn.classList.add('active');
      markInteracted('urge');
      try {
        const res = await fetch('/api/interactions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ slug: slug, action: 'urge' }) });
        const data = await res.json();
        if (data.ok && urgeCount) { urgeCount.textContent = String(data.counts.urges); showMsg('催更成功，作者收到啦！'); }
      } catch(e) {}
    });

    if (hasInteracted('like')) likeBtn.classList.add('active');
    if (hasInteracted('urge')) urgeBtn.classList.add('active');
    loadCounts();
  })();
</script>

<style>
  .interaction-bar {
    display: flex; justify-content: center; gap: 28px; align-items: center;
    margin-top: 60px; padding: 36px 0 16px;
    border-top: 1px solid var(--border);
    position: relative;
  }
  .int-btn {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 24px;
    font-family: var(--font-body); font-size: 15px; font-weight: 500;
    color: var(--text-mid);
    background: var(--cream); border: 1px solid var(--border);
    border-radius: 40px; cursor: pointer;
    transition: all 0.25s;
  }
  .int-btn:hover { border-color: var(--teal); color: var(--teal); }
  .int-btn.active { border-color: var(--teal); color: var(--teal); background: #f0f7f9; }
  .like-btn.active svg { fill: var(--teal); stroke: var(--teal); }
  .urge-btn.active { border-color: var(--coral); color: var(--coral); background: #fef7f5; }
  .urge-btn.active svg { stroke: var(--coral); }
  .btn-label { font-size: 13px; letter-spacing: 0.5px; }
  .int-msg {
    position: absolute; bottom: -24px; left: 50%; transform: translateX(-50%);
    font-size: 13px; color: var(--teal); white-space: nowrap;
  }
  @media (max-width: 640px) {
    .interaction-bar { gap: 16px; }
    .int-btn { padding: 10px 18px; font-size: 14px; }
  }
</style>
