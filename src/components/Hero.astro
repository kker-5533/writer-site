---
interface Props {
  author: string;
  subtitle: string;
  intro: string;
  coverImage: string;
}

const { author, subtitle, intro, coverImage } = Astro.props;
---

<header id="hero" style={`background-image: linear-gradient(rgba(0,0,0,.4), rgba(0,0,0,.3)), url('${coverImage}')`}>
  <div class="hero-inner">
    <div class="hero-avatar">{author[0]}</div>
    <h1>{author}</h1>
    <p class="subtitle">{subtitle}</p>
    <p class="intro" set:html={intro.replace(/\n/g, '<br>')} />
  </div>
</header>

<style>
  #hero {
    position: relative;
    min-height: 70vh;
    display: flex; align-items: center; justify-content: center;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    text-align: center;
    padding: 80px 0;
  }
  #hero::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 60px;
    background: linear-gradient(to top, var(--bg) 0%, transparent 100%);
  }
  #hero .hero-inner {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; align-items: center;
    padding: 40px 28px;
  }
  .hero-avatar {
    width: 80px; height: 80px; border-radius: 50%;
    background: rgba(255,255,255,.15); backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center;
    font-size: 30px; font-weight: 700; color: #fff;
    border: 2px solid rgba(255,255,255,.3);
    margin-bottom: 18px;
  }
  #hero h1 {
    font-family: var(--font-heading);
    font-size: 42px; font-weight: 800;
    color: #fff; letter-spacing: 4px;
    margin-bottom: 10px;
    text-shadow: 0 2px 8px rgba(0,0,0,.3);
  }
  #hero .subtitle {
    font-family: var(--font-body);
    font-size: 15px; font-weight: 500;
    color: rgba(255,255,255,.8);
    letter-spacing: 4px;
    margin-bottom: 16px;
  }
  #hero .intro {
    font-family: var(--font-body);
    max-width: 480px; margin: 0 auto;
    font-size: 14px; font-weight: 400;
    color: rgba(255,255,255,.7);
    line-height: 2;
    letter-spacing: 0.5px;
  }

  @media (max-width: 640px) {
    #hero { min-height: 50vh; }
    #hero h1 { font-size: 32px; letter-spacing: 2px; }
    .hero-avatar { width: 60px; height: 60px; font-size: 22px; }
  }
</style>
